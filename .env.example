# ──────────────────────────────────────────────
# RecruitPro — Environment Variables
# Copy to .env and fill in real values
# ──────────────────────────────────────────────

# ── PostgreSQL ───────────────────────────────
POSTGRES_DB=recruitpro
POSTGRES_USER=recruitpro
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# ── Redis ────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Backend (Spring Boot) ────────────────────
BACKEND_PORT=8080
BACKEND_DB_URL=jdbc:postgresql://db:5432/${POSTGRES_DB}
BACKEND_DB_USERNAME=${POSTGRES_USER}
BACKEND_DB_PASSWORD=${POSTGRES_PASSWORD}

JWT_SECRET=your-256-bit-secret-key-change-in-production
JWT_ACCESS_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

SEED_ENABLED=true

# ── Mail (for OTP delivery) ──────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# ── Spring Devtools (dev only) ───────────────
SPRING_DEVTOOLS_RESTART_ENABLED=true
SPRING_DEVTOOLS_LIVERELOAD_ENABLED=true
SPRING_DATASOURCE_HIKARI_INITIALIZATION_FAIL_TIMEOUT=60000

# ── AI Service (FastAPI) ─────────────────────
AI_SERVICE_PORT=8000
AI_SERVICE_HOST=ai-service
AI_SERVICE_MODEL_PATH=/app/models
AI_SERVICE_MODEL_VERSION=v1
AI_SERVICE_URL=http://ai-service:8000

# ── MinIO (S3-compatible storage) ────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://minio:9000
PUBLIC_MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_DEFAULT_BUCKET=recruitpro
MINIO_USE_SSL=false

# ── Frontend Ports ───────────────────────────
FRONTEND_JOBSEEKER_PORT=3000
FRONTEND_COMPANY_PORT=3001
FRONTEND_ADMIN_PORT=3002
