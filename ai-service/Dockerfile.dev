# Development Dockerfile — source is bind-mounted
FROM python:3.11-slim
WORKDIR /app
RUN echo 'Acquire::Retries "5";' > /etc/apt/apt.conf.d/99retries && \
    echo 'Acquire::http::Pipeline-Depth "5";' >> /etc/apt/apt.conf.d/99retries
COPY docker-apt-sources.list /etc/apt/sources.list.d/docker-apt-sources.list
RUN apt-get update && apt-get install -y --no-install-recommends \
        tesseract-ocr \
        tesseract-ocr-eng \
    && rm -rf /var/lib/apt/lists/*
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
COPY scripts ./scripts
# Source is bind-mounted at runtime via docker-compose.dev.yml
EXPOSE 8000
CMD ["uvicorn", "app.main:app", "--reload", "--host", "0.0.0.0", "--port", "8000"]
