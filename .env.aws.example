# ─────────────────────────────────────────────────────────────────────────────
# RecruitPro — AWS Production Environment
# Copy to .env.aws and fill in real values.
#
# IMPORTANT: Set EC2_PUBLIC_IP to your instance's public IPv4 address.
# IMPORTANT: Set CORS_ALLOWED_ORIGINS to match that IP on the correct ports.
#
# Usage:
#   cp .env.aws.example .env.aws
#   # Edit .env.aws and replace YOUR_EC2_PUBLIC_IP with your actual EC2 public IP
#   # Default AWS build-from-source mode:
#   docker compose --env-file .env.aws -f docker-compose.yml -f docker-compose.prod.yml up -d --build
#
#   # AWS mode using DockerHub image for ai-service:
#   docker compose --env-file .env.aws -f docker-compose.yml -f docker-compose.prod.yml -f docker-compose.aws-ai-image.yml up -d --build
# ─────────────────────────────────────────────────────────────────────────────

# ── Nginx exposed ports ────────────────────────────────────────────────────
# JobSeeker (main site) — port 80 on the EC2 security group
JOBSEEKER_PORT=80
# Company portal — port 8081 on the EC2 security group
COMPANY_PORT=8081
# Admin dashboard — port 8082 on the EC2 security group
ADMIN_PORT=8082

# ── EC2 Public IP ─────────────────────────────────────────────────────────
# Replace YOUR_EC2_PUBLIC_IP with your AWS EC2 instance public IPv4 address.
EC2_PUBLIC_IP=YOUR_EC2_PUBLIC_IP

# ── Frontend build-time variables ─────────────────────────────────────────
# Nginx proxies /api/* internally to the backend. Frontend uses relative URLs.
VITE_API_URL=/api

# Google OAuth 2.0 (set to your actual client ID, or leave empty to disable)
VITE_GOOGLE_CLIENT_ID=

# ── Spring profiles ───────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod

# ── PostgreSQL ────────────────────────────────────────────────────────────
POSTGRES_DB=recruitpro
POSTGRES_USER=recruitpro
POSTGRES_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Backend ───────────────────────────────────────────────────────────────
BACKEND_DB_URL=jdbc:postgresql://db:5432/${POSTGRES_DB}
BACKEND_DB_USERNAME=${POSTGRES_USER}
BACKEND_DB_PASSWORD=${POSTGRES_PASSWORD}

JWT_SECRET=CHANGE_THIS_TO_A_VERY_LONG_RANDOM_SECRET
JWT_ACCESS_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# CORS — must include the EC2 public IP on all three portal ports.
# Replace YOUR_EC2_PUBLIC_IP with your actual EC2 instance public IPv4 address.
CORS_ALLOWED_ORIGINS=http://YOUR_EC2_PUBLIC_IP,http://YOUR_EC2_PUBLIC_IP:8081,http://YOUR_EC2_PUBLIC_IP:8082

SEED_ENABLED=false

# ── AI Service ────────────────────────────────────────────────────────────
AI_SERVICE_URL=http://ai-service:8000
# DockerHub image that contains the AI model artifacts.
# Required when deploying with docker-compose.aws-ai-image.yml / just aws-ai-up.
AI_SERVICE_IMAGE=danhdz1310/recruitpro-ai-service:latest

# The DockerHub AI image bakes models into /opt/recruitpro/models.
# Keep this value unless you change ai-service/Dockerfile.dockerhub.
AI_SERVICE_MODEL_PATH=/opt/recruitpro/models
AI_SERVICE_MODEL_VERSION=v1

# OpenAI (optional — leave empty to use local AI models only)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# ── MinIO ────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=CHANGE_MINIO_USER
MINIO_ROOT_PASSWORD=CHANGE_MINIO_PASSWORD
MINIO_ENDPOINT=http://minio:9000
MINIO_DEFAULT_BUCKET=recruitpro
MINIO_USE_SSL=false

# ── Mail ─────────────────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# ── Stripe (required if accepting payments) ───────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=usd

# ── Google OAuth 2.0 ──────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
