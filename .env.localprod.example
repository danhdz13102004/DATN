# ─────────────────────────────────────────────────────────────────────────────
# RecruitPro — Local Production Environment
# Copy to .env.localprod and fill in real values for local testing.
# Usage:
#   cp .env.localprod.example .env.localprod
#   docker compose --env-file .env.localprod -f docker-compose.yml -f docker-compose.prod.yml up --build
# ─────────────────────────────────────────────────────────────────────────────

# ── Nginx exposed ports ────────────────────────────────────────────────────
# JobSeeker (main site)
JOBSEEKER_PORT=80
# Company portal
COMPANY_PORT=8081
# Admin dashboard
ADMIN_PORT=8082

# ── Frontend build-time variables ─────────────────────────────────────────
# In production the Nginx container proxies /api/* to the backend internally.
# Frontend code uses relative URLs so this should be "/api".
VITE_API_URL=/api

# Google OAuth 2.0 (optional — leave empty to disable Google sign-in)
VITE_GOOGLE_CLIENT_ID=

# ── Spring profiles ───────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod

# ── PostgreSQL ────────────────────────────────────────────────────────────
POSTGRES_DB=recruitpro
POSTGRES_USER=recruitpro
POSTGRES_PASSWORD=changeme

# ── Redis ────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Backend ───────────────────────────────────────────────────────────────
BACKEND_DB_URL=jdbc:postgresql://db:5432/${POSTGRES_DB}
BACKEND_DB_USERNAME=${POSTGRES_USER}
BACKEND_DB_PASSWORD=${POSTGRES_PASSWORD}

JWT_SECRET=your-256-bit-secret-key-change-in-production
JWT_ACCESS_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# CORS — local production uses localhost equivalents.
# JobSeeker is on :80 (http://localhost), Company on :8081, Admin on :8082.
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:8081,http://localhost:8082

SEED_ENABLED=false

# ── AI Service ────────────────────────────────────────────────────────────
AI_SERVICE_URL=http://ai-service:8000

# Elasticsearch keyword search
ELASTICSEARCH_ENABLED=false
ELASTICSEARCH_JOBS_INDEX=jobs_search
SPRING_ELASTICSEARCH_URIS=http://elasticsearch:9200
SPRING_ELASTICSEARCH_USERNAME=
SPRING_ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_SECURITY_ENABLED=false
AI_SERVICE_MODEL_PATH=/app/models
AI_SERVICE_MODEL_VERSION=v1

# OpenAI (optional — leave empty to use local AI models only)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# ── MinIO ────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://minio:9000
MINIO_DEFAULT_BUCKET=recruitpro
MINIO_USE_SSL=false

# ── Mail ─────────────────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# ── Stripe (optional — leave empty to disable payments) ──────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=usd

# ── Google OAuth 2.0 ──────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
